generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  publicId         String            @unique
  email            String            @unique
  passwordHash     String
  role             Role
  status           UserStatus        @default(ACTIVE)
  name                   String?
  emailVerified          Boolean           @default(false)
  verificationCode       String?
  verificationCodeExpiry DateTime?
  verificationCodeSentAt DateTime?
  resetToken             String?           @unique
  resetTokenExpiry       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  borrowerRequests BorrowerRequest[]
  broker           Broker?
  conversations    Conversation[]
  messages         Message[]
  reports          Report[]
  adminActions     AdminAction[] @relation("adminActions")
  noticesSent      AdminNotice[] @relation("adminNoticesSent")
  noticesReceived  AdminNotice[] @relation("adminNoticesReceived")

  @@map("users")
}

model BorrowerRequest {
  id                 String               @id @default(cuid())
  publicId           String               @unique
  borrowerId         String
  mortgageCategory   MortgageCategory     @default(RESIDENTIAL)
  productTypes       String[]             @default([])
  province           String
  city               String?
  details            Json?
  desiredTimeline    String?
  notes              String?
  status             RequestStatus        @default(PENDING_APPROVAL)
  rejectionReason    String?
  schemaVersion      Int                  @default(1)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Legacy columns (kept for v1 backward compatibility)
  requestType        RequestType?
  propertyType       PropertyType?
  priceRangeMin      Int?
  priceRangeMax      Int?
  downPaymentPercent String?
  incomeRangeMin     Int?
  incomeRangeMax     Int?
  employmentType     EmploymentType?
  creditScoreBand    CreditScoreBand?
  debtRangeMin       Int?
  debtRangeMax       Int?
  mortgageAmountMin  Int?
  mortgageAmountMax  Int?
  preferredTerm      String?
  preferredType      MortgageType?
  closingTimeline    String?

  borrower           User                 @relation(fields: [borrowerId], references: [id])
  introductions      BrokerIntroduction[]
  conversations      Conversation[]

  @@map("borrower_requests")
}

model Broker {
  id                 String               @id @default(cuid())
  userId             String               @unique
  brokerageName      String
  province           String
  licenseNumber      String
  mortgageCategory   BrokerMortgageCategory @default(BOTH)
  bio                String?
  yearsExperience    Int?
  areasServed        String?
  specialties        String?
  profilePhoto       String?
  verificationStatus VerificationStatus   @default(PENDING)
  subscriptionTier   SubscriptionTier     @default(FREE)
  responseCredits    Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  introductions      BrokerIntroduction[]
  user               User                 @relation(fields: [userId], references: [id])
  conversations      Conversation[]
  subscription       Subscription?
  creditPurchases    CreditPurchase[]

  @@map("brokers")
}

model BrokerIntroduction {
  id                String          @id @default(cuid())
  requestId         String
  brokerId          String
  howCanHelp        String
  experience        String?
  lenderNetwork     String?
  processNotes      String?
  personalMessage   String
  estimatedTimeline String?
  createdAt         DateTime        @default(now())
  broker            Broker          @relation(fields: [brokerId], references: [id])
  request           BorrowerRequest @relation(fields: [requestId], references: [id])

  @@unique([requestId, brokerId])
  @@map("broker_introductions")
}

model Conversation {
  id                 String             @id @default(cuid())
  publicId           String             @unique
  requestId          String
  borrowerId         String
  brokerId           String
  status             ConversationStatus @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  borrowerLastReadAt DateTime?          @map("borrower_last_read_at")
  brokerLastReadAt   DateTime?          @map("broker_last_read_at")
  borrower           User               @relation(fields: [borrowerId], references: [id])
  broker             Broker             @relation(fields: [brokerId], references: [id])
  request            BorrowerRequest    @relation(fields: [requestId], references: [id])
  messages           Message[]

  @@unique([requestId, brokerId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model Subscription {
  id        String             @id @default(cuid())
  brokerId  String             @unique
  tier      SubscriptionTier
  status    SubscriptionStatus @default(ACTIVE)
  startedAt DateTime           @default(now())
  endedAt   DateTime?
  broker    Broker             @relation(fields: [brokerId], references: [id])

  @@map("subscriptions")
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  status     ReportStatus @default(OPEN)
  adminNotes String?
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  reporter   User         @relation(fields: [reporterId], references: [id])

  @@map("reports")
}

enum Role {
  BORROWER
  BROKER
  ADMIN
}

enum MortgageCategory {
  RESIDENTIAL
  COMMERCIAL
}

enum BrokerMortgageCategory {
  RESIDENTIAL
  COMMERCIAL
  BOTH
}

enum RequestType {
  PURCHASE
  REFINANCE
  RENEWAL
}

enum PropertyType {
  CONDO
  TOWNHOUSE
  DETACHED
  OTHER
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  SELF_EMPLOYED
  CONTRACT
  RETIRED
  OTHER
}

enum CreditScoreBand {
  EXCELLENT
  GOOD
  FAIR
  POOR
  NOT_SURE
}

enum MortgageType {
  FIXED
  VARIABLE
  NOT_SURE
}

enum RequestStatus {
  PENDING_APPROVAL
  OPEN
  IN_PROGRESS
  CLOSED
  EXPIRED
  REJECTED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum SubscriptionTier {
  FREE
  BASIC
  PRO
  PREMIUM
}

enum CreditPackType {
  SMALL
  LARGE
}

model CreditPurchase {
  id        String         @id @default(cuid())
  brokerId  String
  packType  CreditPackType
  credits   Int
  amount    Int            // price in cents
  createdAt DateTime       @default(now())
  broker    Broker         @relation(fields: [brokerId], references: [id])

  @@map("credit_purchases")
}

model AdminNotice {
  id        String   @id @default(cuid())
  adminId   String   @map("admin_id")
  userId    String   @map("user_id")
  subject   String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  admin     User     @relation("adminNoticesSent", fields: [adminId], references: [id])
  user      User     @relation("adminNoticesReceived", fields: [userId], references: [id])

  @@map("admin_notices")
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // CREDIT_ADJUST, SUSPEND_USER, BAN_USER, REACTIVATE_USER, VERIFY_BROKER, REJECT_BROKER
  targetType String   // USER, BROKER
  targetId   String
  details    String?  // JSON or free-text with action-specific data
  reason     String?
  createdAt  DateTime @default(now())
  admin      User     @relation("adminActions", fields: [adminId], references: [id])

  @@map("admin_actions")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum ConversationStatus {
  ACTIVE
  CLOSED
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
  DISMISSED
}
