generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  publicId         String            @unique
  email            String            @unique
  passwordHash     String?
  googleId         String?           @unique
  appleId          String?           @unique
  role             Role
  status           UserStatus        @default(ACTIVE)
  name                   String?
  emailVerified          Boolean           @default(false)
  verificationCode       String?
  verificationCodeExpiry DateTime?
  verificationCodeSentAt DateTime?
  resetToken             String?           @unique
  resetTokenExpiry       DateTime?
  preferences            Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  borrowerRequests BorrowerRequest[]
  broker           Broker?
  conversations    Conversation[]
  messages         Message[]
  reports          Report[]
  adminActions     AdminAction[] @relation("adminActions")
  noticesSent      AdminNotice[] @relation("adminNoticesSent")
  noticesReceived  AdminNotice[] @relation("adminNoticesReceived")
  deviceTokens     DeviceToken[]
  blockedUsers     UserBlock[]   @relation("blocker")
  blockedBy        UserBlock[]   @relation("blocked")

  @@index([status])
  @@index([role])
  @@map("users")
}

// User-to-user block list. Required by Apple guideline 1.2 for any UGC app
// with chat or social features. A row means: `blocker` has blocked `blocked`,
// hiding all communication in both directions until the row is removed.
model UserBlock {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  @@id([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

model DeviceToken {
  id             String   @id @default(cuid())
  userId         String
  token          String   @unique
  platform       DevicePlatform
  locale         String   @default("ko")
  deviceName     String?
  appVersion     String?
  pushEnabled    Boolean  @default(true)
  mutedUntil     DateTime?
  lastActiveAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, pushEnabled])
  @@map("device_tokens")
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

model BorrowerRequest {
  id                 String               @id @default(cuid())
  publicId           String               @unique
  borrowerId         String
  mortgageCategory   MortgageCategory     @default(RESIDENTIAL)
  productTypes       String[]             @default([])
  province           String
  city               String?
  details            Json?
  desiredTimeline    String?
  notes              String?
  status             RequestStatus        @default(PENDING_APPROVAL)
  rejectionReason    String?
  schemaVersion      Int                  @default(2)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  borrower           User                 @relation(fields: [borrowerId], references: [id])
  conversations      Conversation[]
  brokerSeens        BrokerRequestSeen[]

  @@index([borrowerId])
  @@index([borrowerId, status])
  @@index([status, createdAt])
  @@map("borrower_requests")
}

model Broker {
  id                 String               @id @default(cuid())
  userId             String               @unique
  brokerageName      String
  province           String
  licenseNumber      String
  phone              String?
  mortgageCategory   BrokerMortgageCategory @default(BOTH)
  bio                String?
  yearsExperience    Int?
  areasServed        String?
  specialties        String?
  profilePhoto       String?
  stripeCustomerId   String?              @unique @map("stripe_customer_id")
  verificationStatus VerificationStatus   @default(PENDING)
  subscriptionTier   SubscriptionTier     @default(FREE)
  responseCredits    Int                  @default(0)
  lastRequestsSeenAt DateTime?            @map("last_requests_seen_at")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User                 @relation(fields: [userId], references: [id])
  conversations      Conversation[]
  subscription       Subscription?
  seenRequests       BrokerRequestSeen[]
  @@index([verificationStatus])
  @@index([subscriptionTier])
  @@map("brokers")
}

// Per-broker, per-request "seen" tracker for unread indicators on the browse page.
// Layers on top of Broker.lastRequestsSeenAt (which is kept as a legacy fallback).
// A row here means: this broker has acknowledged this request (via opening it OR
// leaving the browse page with it visible). No row = still "new" for this broker.
model BrokerRequestSeen {
  brokerId  String
  requestId String
  seenAt    DateTime @default(now())
  broker    Broker          @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  request   BorrowerRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  @@id([brokerId, requestId])
  @@index([brokerId])
  @@map("broker_request_seen")
}



model Conversation {
  id                 String             @id @default(cuid())
  publicId           String             @unique
  requestId          String
  borrowerId         String
  brokerId           String
  status             ConversationStatus @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  borrowerLastReadAt DateTime?          @map("borrower_last_read_at")
  brokerLastReadAt   DateTime?          @map("broker_last_read_at")
  borrower           User               @relation(fields: [borrowerId], references: [id])
  broker             Broker             @relation(fields: [brokerId], references: [id])
  request            BorrowerRequest    @relation(fields: [requestId], references: [id])
  messages           Message[]

  @@unique([requestId, brokerId])
  @@index([borrowerId])
  @@index([brokerId])
  @@index([requestId])
  @@index([status, updatedAt])
  @@index([status, createdAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([conversationId, senderId, createdAt])
  @@map("messages")
}

model Subscription {
  id                   String             @id @default(cuid())
  brokerId             String             @unique
  tier                 SubscriptionTier
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  pendingTier          SubscriptionTier?  @map("pending_tier")
  startedAt            DateTime           @default(now())
  endedAt              DateTime?
  broker               Broker             @relation(fields: [brokerId], references: [id])

  @@map("subscriptions")
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  status     ReportStatus @default(OPEN)
  adminNotes String?
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  reporter   User         @relation(fields: [reporterId], references: [id])

  @@index([status, createdAt])
  @@index([reporterId, targetType, targetId])
  @@map("reports")
}

enum Role {
  BORROWER
  BROKER
  ADMIN
}

enum MortgageCategory {
  RESIDENTIAL
  COMMERCIAL
}

enum BrokerMortgageCategory {
  RESIDENTIAL
  COMMERCIAL
  BOTH
}


enum RequestStatus {
  PENDING_APPROVAL
  OPEN
  IN_PROGRESS
  CLOSED
  EXPIRED
  REJECTED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum SubscriptionTier {
  FREE
  BASIC
  PRO
  PREMIUM
}


model AdminNotice {
  id        String   @id @default(cuid())
  adminId   String   @map("admin_id")
  userId    String   @map("user_id")
  subject   String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  admin     User     @relation("adminNoticesSent", fields: [adminId], references: [id])
  user      User     @relation("adminNoticesReceived", fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("admin_notices")
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // CREDIT_ADJUST, SUSPEND_USER, BAN_USER, REACTIVATE_USER, VERIFY_BROKER, REJECT_BROKER
  targetType String   // USER, BROKER
  targetId   String
  details    String?  // JSON or free-text with action-specific data
  reason     String?
  createdAt  DateTime @default(now())
  admin      User     @relation("adminActions", fields: [adminId], references: [id])

  @@index([action, createdAt])
  @@index([createdAt])
  @@map("admin_actions")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum ConversationStatus {
  ACTIVE
  CLOSED
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
  DISMISSED
}
