{
  "name": "mortgage-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "seed": "npx tsx prisma/seed.ts",
    "seed:mock": "npm run seed -- mock",
    "seed:empty": "npm run seed -- empty",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:component": "vitest run tests/component",
    "test:invariants": "vitest run tests/invariants",
    "test:concurrency": "vitest run tests/concurrency --no-file-parallelism",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@supabase/supabase-js": "^2.100.1",
    "@vercel/analytics": "^2.0.1",
    "apple-signin-auth": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "expo-server-sdk": "^6.1.0",
    "google-auth-library": "^10.6.2",
    "i18next": "^25.10.10",
    "next": "^16.2.1",
    "next-auth": "^4.24.13",
    "next-i18next": "^15.4.3",
    "next-sitemap": "^4.2.3",
    "posthog-js": "^1.364.6",
    "posthog-node": "^5.28.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^25.0.1",
    "node-mocks-http": "^1.16.2",
    "postcss": "^8",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.8",
    "vitest-mock-extended": "^2.0.2"
  }
}
